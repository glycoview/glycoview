# syntax=docker/dockerfile:1.7

FROM golang:1.25-bookworm AS build
WORKDIR /workspace

ARG TARGETARCH

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH:-amd64} go build -trimpath -ldflags="-s -w" -o /out/glycoview-agent ./cmd/glycoview-agent

FROM docker:28-cli
WORKDIR /app

COPY --from=build /out/glycoview-agent /app/glycoview-agent

EXPOSE 8090

ENTRYPOINT ["/app/glycoview-agent"]
