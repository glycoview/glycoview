#cloud-config
hostname: glycoview
timezone: Europe/Berlin

write_files:
  - path: /opt/glycoview/stack/.env
    permissions: "0640"
    content: |
      GLYCOVIEW_DOMAIN=glycoview.local
      LETSENCRYPT_EMAIL=admin@example.com
      POSTGRES_DB=glycoview
      POSTGRES_USER=glycoview
      POSTGRES_PASSWORD=change-me
      GLYCOVIEW_AGENT_TOKEN=replace-with-a-long-random-secret
      GLYCOVIEW_TAG=latest
      GLYCOVIEW_AGENT_TAG=latest

runcmd:
  - systemctl enable docker
  - systemctl start docker
  - systemctl enable glycoview-appliance-bootstrap.service
  - systemctl start glycoview-appliance-bootstrap.service
